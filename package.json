{
  "name": "slack-multi-agent",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "deploy": "turbo run deploy",
    "setup:slack": "ts-node scripts/setup-slack.ts",
    "setup:supabase": "ts-node scripts/setup-supabase.ts",
    "setup:redis": "ts-node scripts/setup-redis.ts",
    "test": "turbo run test",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.12.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
