# ══════════════════════════════════════════════════════════════════════════════
#  Slack Workplace Agent Team Generator — Environment Configuration
#  Copy this to .env and fill in your values.
#  NEVER commit .env to source control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── NVIDIA NIM (FIRST-CLASS PROVIDER) ─────────────────────────────────────────
# Get your free API key at: https://build.nvidia.com/nim/apis
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_DEFAULT_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# Other supported NIM models:
#   nvidia/nemotron-4-340b-instruct
#   nvidia/hermes-3-llama-3.1-70b
#   meta/llama-3.1-405b-instruct
#   mistralai/mixtral-8x22b-instruct-v0.1
#   nv-mistralai/mistral-nemo-12b-instruct

# ── OpenAI (optional — fallback provider) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o

# ── Anthropic (optional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ── Groq (optional — ultra-fast inference) ────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_DEFAULT_MODEL=llama-3.1-70b-versatile

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot Token:   https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...
# App Token:   https://api.slack.com/apps → Basic Information → App-Level Tokens → Generate (connections:write)
SLACK_APP_TOKEN=xapp-...
# Signing Secret: https://api.slack.com/apps → Basic Information → App Credentials
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Admin token (optional, for workspace-admin operations):
# SLACK_ADMIN_TOKEN=xoxp-...

# ── Redis (conversation memory) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./agents.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://agents:agents@localhost:5432/agents

# ── External Tool Plugins ─────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=...
GOOGLE_DRIVE_CREDENTIALS_JSON=

# ── Safety defaults ───────────────────────────────────────────────────────────
DEFAULT_AUTONOMY=review        # off | review | full
SAFETY_ENABLED=true
CONTENT_FILTER_THRESHOLD=0.7

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_API_KEY=              # optional bearer token to protect dashboard

# ── Observability ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true
TRACE_ENABLED=true
# OTEL_ENDPOINT=http://localhost:4317  # OpenTelemetry collector (optional)
